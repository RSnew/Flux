{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Flux",
    "scopeName": "source.flux",
    "patterns": [
        { "include": "#comments" },
        { "include": "#annotations" },
        { "include": "#strings" },
        { "include": "#keywords-control" },
        { "include": "#keywords-declaration" },
        { "include": "#keywords-other" },
        { "include": "#constants" },
        { "include": "#stdlib-modules" },
        { "include": "#builtin-functions" },
        { "include": "#function-definition" },
        { "include": "#function-call" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#punctuation" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "name": "comment.line.double-slash.flux",
            "match": "//.*$"
        },
        "annotations": {
            "patterns": [
                {
                    "name": "entity.name.tag.flux",
                    "match": "@supervised"
                },
                {
                    "name": "constant.language.flux",
                    "match": "\\.always|\\.never"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.flux",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.flux",
                    "match": "\\\\[nrt\"\\\\]"
                },
                {
                    "name": "meta.interpolation.flux",
                    "begin": "\\\\\\(",
                    "beginCaptures": {
                        "0": { "name": "punctuation.section.interpolation.begin.flux" }
                    },
                    "end": "\\)",
                    "endCaptures": {
                        "0": { "name": "punctuation.section.interpolation.end.flux" }
                    },
                    "contentName": "source.flux.embedded",
                    "patterns": [
                        { "include": "$self" }
                    ]
                }
            ]
        },
        "keywords-control": {
            "name": "keyword.control.flux",
            "match": "\\b(if|else|while|for|in|return)\\b"
        },
        "keywords-declaration": {
            "name": "storage.type.flux",
            "match": "\\b(let|var|conf|fn|func|module|enum)\\b"
        },
        "keywords-other": {
            "patterns": [
                {
                    "name": "keyword.other.flux",
                    "match": "\\b(persistent|state|migrate|interface|exception|spawn|async|await)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.flux",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language.nil.flux",
                    "match": "\\bnil\\b"
                }
            ]
        },
        "stdlib-modules": {
            "name": "support.class.stdlib.flux",
            "match": "\\b(File|Json|Http|Time)\\b(?=\\.)"
        },
        "builtin-functions": {
            "name": "support.function.builtin.flux",
            "match": "\\b(print|str|len|type|range|panic|Map)\\b(?=\\s*\\()"
        },
        "function-definition": {
            "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
            "captures": {
                "1": { "name": "storage.type.flux" },
                "2": { "name": "entity.name.function.flux" }
            }
        },
        "function-call": {
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
            "captures": {
                "1": { "name": "entity.name.function.call.flux" }
            }
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.flux",
                    "match": "-?\\b\\d+\\.\\d+\\b"
                },
                {
                    "name": "constant.numeric.integer.flux",
                    "match": "-?\\b\\d+\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.logical.flux",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.comparison.flux",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.assignment.flux",
                    "match": "="
                },
                {
                    "name": "keyword.operator.arrow.flux",
                    "match": "->"
                },
                {
                    "name": "keyword.operator.arithmetic.flux",
                    "match": "[+\\-*/%]"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.definition.block.flux",
                    "match": "[{}]"
                },
                {
                    "name": "punctuation.definition.array.flux",
                    "match": "[\\[\\]]"
                },
                {
                    "name": "punctuation.separator.flux",
                    "match": "[,:]"
                },
                {
                    "name": "punctuation.accessor.flux",
                    "match": "\\."
                }
            ]
        },
        "identifiers": {
            "name": "variable.other.flux",
            "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
    }
}
